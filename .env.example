# Jarvis Assistant Environment Key

# Get your API key from: https://aistudio.google.com/app/apikey
JARVIS_API_KEY=

# Model Provider (google or openai)
JARVIS_MODEL_PROVIDER=google

# Optional: Dry Run (1 to enable, 0 to disable)
# JARVIS_DRY_RUN=0

# Set your Browser Use API Key
BROWSER_USE_API_KEY=
